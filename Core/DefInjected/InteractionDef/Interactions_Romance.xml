    <li>r_logentry->[INITIATOR_nameDef] told [RECIPIENT_nameDef] that it would be best to see other people.</li>
  -->
  <Breakup.logRulesInitiator.rulesStrings>
    <li>r_logentry->[INITIATOR_nameDef] fragte [RECIPIENT_nameDef] nach einer Auszeit.</li>
    <li>r_logentry->[INITIATOR_nameDef] erklärte [RECIPIENT_nameDef], dass etwas Abstand notwendig ist.</li>
    <li>r_logentry->[INITIATOR_nameDef] sagte [RECIPIENT_nameDef], dass es zwischen ihnen nicht mehr funktioniert.</li>
    <li>r_logentry->[INITIATOR_nameDef] sagte [RECIPIENT_nameDef], dass es wohl besser wäre, wenn sie sich nach anderen umsehen.</li>
  </Breakup.logRulesInitiator.rulesStrings>
  
  <!-- EN: marriage proposal -->
  <MarriageProposal.label>Heiratsantrag</MarriageProposal.label>
  <!-- EN:
    <li>r_logentry->[INITIATOR_nameDef] proposed marriage to [RECIPIENT_nameDef].</li>
